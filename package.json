{
  "name": "twenty-crm-mcp-server",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server for Twenty CRM integration. Enables natural language interactions with your CRM data through Claude and other AI assistants.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:http": "node server-http.js",
    "digest": "node daily-digest.js",
    "digest:dry-run": "node daily-digest.js --dry-run",
    "dev": "node --inspect index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "nodemailer": "^9.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "twenty",
    "crm",
    "server",
    "claude",
    "ai",
    "assistant",
    "natural-language",
    "api",
    "integration"
  ],
