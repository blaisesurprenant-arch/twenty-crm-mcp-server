# Twenty CRM API Configuration
TWENTY_API_KEY=your_api_key_here
TWENTY_BASE_URL=https://api.twenty.com

# For self-hosted instances, change TWENTY_BASE_URL to your domain:
# TWENTY_BASE_URL=https://your-twenty-instance.com

# Workspace member ID of the dedicated "Claude" bot account in Twenty.
# Invite it via Twenty > Settings > Members, then look up its ID with the
# list_workspace_members tool and paste it here.
CLAUDE_ASSIGNEE_ID=

# --- server-http.js (hosted/remote MCP connector) ---
PORT=3939
# Long random secret — required for every request to the hosted server.
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# --- daily-digest.js (cron job, 9:00 AM) ---
GMAIL_USER=your_address@gmail.com
# Generate a dedicated Gmail App Password at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
